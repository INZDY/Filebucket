# If using Supabase and your local network only supports IPv4, use the Supavisor connection pooler URL on port 5432 (Session Mode) rather than the direct connection (which defaults to IPv6-only).
# Format: postgresql://postgres.[project-ref]:[password]@aws-[region].pooler.supabase.com:5432/[database]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/filebucket?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
FILEBUCKET_ADMIN_EMAIL="admin@filebucket.local"
FILEBUCKET_ADMIN_PASSWORD="replace-with-a-strong-password"

